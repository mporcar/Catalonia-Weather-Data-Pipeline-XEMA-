{
  "name": "Catalonia Weather Data Pipeline",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",
  "features": {
    "ghcr.io/devcontainers/features/terraform:1": "latest"
  },
  "remoteEnv": {
    "AIRFLOW_HOME": "${containerWorkspaceFolder}/airflow_home",
    "AIRFLOW__CORE__DAGS_FOLDER": "${containerWorkspaceFolder}/dags",
    "AIRFLOW__CORE__LOAD_EXAMPLES": "False"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "hashicorp.terraform",
        "dbtlabs.dbt-power-user",
        "tamasfe.even-better-toml",
        "redhat.vscode-yaml"
      ]
    }
  },
  "postCreateCommand": "bash .devcontainer/setup_auth.sh && pip install --no-cache-dir -r dags/scripts/requirements.txt && cd terraform && terraform init",
  "postStartCommand": "airflow db init || echo 'Airflow DB already initialized'",
  "remoteUser": "vscode"
}
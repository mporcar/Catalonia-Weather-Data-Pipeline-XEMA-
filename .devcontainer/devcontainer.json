{
  "name": "Catalonia Weather Data Pipeline",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",
  "features": {
    "ghcr.io/devcontainers/features/terraform:1": "latest"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "hashicorp.terraform",
        "dbtlabs.dbt-power-user",
        "tamasfe.even-better-toml",
        "redhat.vscode-yaml"
      ]
    }
  },
  "postCreateCommand": "pip install -r dags/scripts/requirements.txt && cd terraform && terraform init",
  "remoteUser": "vscode"
}